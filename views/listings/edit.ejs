<% layout("/layouts/boilerplate") %>

<body>
    <div class="row mt-3">
    <div class="col-8 offset-2">
        <br>

    <h3>Edit Listing</h3>
    <br>

    <form
        method="POST"
        action="/listings/<%= listingById._id %>?_method=PUT"
    >

        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input
                type="text"
                id="title"
                name="listing[title]"
                value="<%= listingById.title %>"
                placeholder="Title"
                class="form-control"
            >
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea
                id="description"
                name="listing[description]"
                class="form-control"
                placeholder="Description"
            ><%= listingById.description %></textarea>
        </div>

        <div class="mb-3">
            <label for="image" class="form-label">Image URL</label>
            <input
                type="text"
                id="image"
                name="listing[image][url]"
                value="<%= listingById.image.url %>"
                placeholder="Enter image URL/link"
                class="form-control"
            >
        </div>

        <div class="row">

            <div class="mb-3 col-md-4">
                <div class="mb-3">
                <label for="price" class="form-label">Price</label>
                <input
                type="number"
                id="price"
                name="listing[price]"
                value="<%= listingById.price %>"
                placeholder="Enter price"
                class="form-control"
                >
               </div>
            
            </div>

            <div class="mb-3 col-md-8">
                <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input
                type="text"
                id="country"
                name="listing[country]"
                value="<%= listingById.country %>"
                placeholder="Enter country"
                class="form-control"
                >
                </div>
            </div>
          
        </div>
        

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input
                type="text"
                id="location"
                name="listing[location]"
                value="<%= listingById.location %>"
                placeholder="Enter location"
                class="form-control"
            >
        </div>

        <button type="submit" class="btn btn-dark edit-btn">
            Update Listing
        </button>

    </form>

    </div>
  </div>

</body>